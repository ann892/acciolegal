<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title }} — Accio Legal</title>
<style>
{{ css | safe }}

/* Floating Save-as-PDF button — visible on screen, hidden when printing */
.save-pdf-btn {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 9999;
  background: #C8A24B;
  color: #07182B;
  border: none;
  padding: 12px 20px;
  border-radius: 8px;
  font-weight: 800;
  font-size: 14px;
  letter-spacing: 0.3px;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}
.save-pdf-btn:hover { background: #D4B266; }
@media print { .save-pdf-btn { display: none !important; } }
</style>
</head>
<body>

<button class="save-pdf-btn" onclick="window.print()" title="Use 'Save as PDF' as the destination in the print dialog">
  ⬇  Save as PDF
</button>

<!-- =========================================================
     COVER
     ========================================================= -->
<section class="page cover">
  <div class="cover-mark">
    <div class="circle-mark"><span>AL</span></div>
  </div>
  <div class="cover-firm">ACCIO LEGAL</div>
  <h1 class="cover-title">{{ title }}</h1>
  <div class="cover-rule"></div>
  <p class="cover-lede">{{ opening_paragraph }}</p>

  <div class="cover-bullets">
    <div class="cover-bullets-label">This proposal outlines our end-to-end legal approach to:</div>
    <ul>
      {% for b in approach_bullets %}<li>{{ b }}</li>{% endfor %}
    </ul>
  </div>

  <div class="cover-footer">
    Confidential · Prepared by Accio Legal · {{ generated_date }}
  </div>
</section>

<!-- =========================================================
     SCOPE — phases timeline
     ========================================================= -->
<section class="page section-deep">
  <div class="page-header">
    <span class="page-eyebrow">Scope</span>
    <h2 class="section-title">{{ scope_section_title }}</h2>
    <p class="section-intro">{{ scope_section_intro }}</p>
  </div>

  <div class="phases-timeline">
    {% for phase in phases %}
    <div class="phase">
      <div class="phase-num">{{ loop.index }}</div>
      <h3 class="phase-name">{{ phase.name }}</h3>
      <p class="phase-frame">{{ phase.framing_sentence }}</p>

      {% if phase.scope_bullets %}
      <div class="block-label">Scope of Work</div>
      <ul class="phase-bullets">
        {% for b in phase.scope_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
      {% endif %}

      {% if phase.outcome_bullets %}
      <div class="block-label outcome-label">Outcome</div>
      <ul class="phase-bullets outcome-bullets">
        {% for b in phase.outcome_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>

<!-- =========================================================
     DELIVERABLES + COST
     ========================================================= -->
<section class="page">
  <div class="page-header">
    <span class="page-eyebrow">Deliverables &amp; Cost</span>
    <h2 class="section-title">What you receive · What you invest</h2>
  </div>

  <div class="deliverables">
    <div class="block-label">Deliverables</div>
    <ul class="deliverables-list">
      {% for d in deliverables %}<li>{{ d }}</li>{% endfor %}
    </ul>
  </div>

  <div class="cost-section">
    <div class="block-label">Summary of Costs</div>
    <table class="cost-table">
      <thead>
        <tr>
          <th>Service</th>
          <th>Duration / TAT</th>
          <th>Pricing (INR)</th>
        </tr>
      </thead>
      <tbody>
        {% for row in cost_table %}
        <tr>
          <td>{{ row.service }}</td>
          <td>{{ row.tat }}</td>
          <td class="amt">{% if row.fee_inr %}₹{{ '{:,}'.format(row.fee_inr) }}{% else %}TBD{% endif %}</td>
        </tr>
        {% endfor %}
        {% if total_fee_inr %}
        <tr class="total-row">
          <td>Total</td>
          <td></td>
          <td class="amt">₹{{ '{:,}'.format(total_fee_inr) }}</td>
        </tr>
        {% endif %}
      </tbody>
    </table>

    <p class="exclusions">{{ exclusions_note }}</p>
    {% if deferred_note %}
    <p class="deferred"><strong>Note:</strong> {{ deferred_note }}</p>
    {% endif %}
  </div>
</section>

<!-- =========================================================
     NEXT STEPS
     ========================================================= -->
<section class="page section-soft next-steps-section">
  <div class="page-header">
    <span class="page-eyebrow">Next Steps</span>
    <h2 class="section-title">How we move forward</h2>
  </div>

  <ol class="next-steps">
    {% for step in next_steps %}<li>{{ step }}</li>{% endfor %}
  </ol>
</section>

<!-- =========================================================
     ABOUT ACCIO + WHY
     ========================================================= -->
<section class="page section-deep">
  <div class="page-header">
    <span class="page-eyebrow">About</span>
    <h2 class="section-title">About Accio Legal</h2>
    <p class="section-intro">A startup-and-corporate-focused boutique with deep experience in Indian and global markets.</p>
  </div>

  <div class="why-grid">
    <div class="why-card">
      <div class="why-icon-text">●  GLOBAL</div>
      <h4>Global Reach</h4>
      <p>Deep understanding of legal requirements in India and global markets — across corporate, IP, and cross-border transactions.</p>
    </div>
    <div class="why-card">
      <div class="why-icon-text">●  EFFICIENT</div>
      <h4>Cost-Effective</h4>
      <p>Flat-fee, phase-based billing tailored for high-growth companies. You focus on growth, we handle the legal.</p>
    </div>
    <div class="why-card">
      <div class="why-icon-text">●  RESPONSIVE</div>
      <h4>Dedicated Support</h4>
      <p>A senior-led team and a partner-on-WhatsApp ethos — round-the-clock legal experts by your side.</p>
    </div>
    <div class="why-card">
      <div class="why-icon-text">●  SCALABLE</div>
      <h4>Scalable Solutions</h4>
      <p>Engagement structures and documentation that grow with you — from incorporation to Series A and beyond.</p>
    </div>
  </div>
</section>

